class LogProcessor(DataProcessor):
    def validate(self, data: Any) -> bool:
        return isinstance(data, str) and ":" in data.strip()

    def process(self, data: Any) -> str:
        if not self.validate(data):
            return "Error: Invalid log data"

        level, _, message = data.partition(":")
        level = level.upper().strip()

        detected = next(
            (l for l in ("CRITICAL", "ERROR", "WARNING", "INFO", "DEBUG") if l in level),
            "INFO",
        )
        prefix = "[ALERT]" if detected in ("CRITICAL", "ERROR") else f"[{detected}]"

        return f"{prefix} {detected} level detected: {message.strip()}"
