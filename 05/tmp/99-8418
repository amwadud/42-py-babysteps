class DataProcessor(ABC):
    @abstractmethod
    def process(self, data: Any) -> str:
        pass

    @abstractmethod
    def validate(self, data: Any) -> bool:
        pass

    def format_output(self, result: str) -> str:
        return result


class NumericProcessor(DataProcessor):
    def process(self, data: list | tuple | int | float) -> str:
        try:
            if isinstance(data, (list, tuple)):
                numbers = [float(x) for x in data if isinstance(x, (int, float))]
                if numbers:
                    return f"sum={sum(numbers)}, avg={sum(numbers) / len(numbers)}"
                return "No numeric values found"
            return str(float(data))
        except (ValueError, TypeError, OverflowError) as e:
            return f"Error processing data: {e}"

    def validate(self, data: list | tuple | int | float) -> bool:
        if isinstance(data, (list, tuple)):
            return any(isinstance(x, (int, float)) for x in data)
        return isinstance(data, (int, float))