    def validate(self, data: Any) -> bool: ...

    def format_output(self, result: str) -> str:
        return result


class NumericProcessor(DataProcessor):
    def process(self, data: Any) -> str:
        return str(data)


class TextProcessor(DataProcessor):
    pass


class LogProcessor(DataProcessor):
    pass


