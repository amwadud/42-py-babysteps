#!/usr/bin/env python3

from abc import ABC, abstractmethod
from typing import Any


class DataProcessor(ABC):
    @abstractmethod
    def process(self, data: Any) -> str:
        pass

    @abstractmethod
    def validate(self, data: Any) -> bool:
        pass

    def format_output(self, result: str) -> str:
        return result


class NumericProcessor(DataProcessor):
    def process(self, data: list | tuple | int | float) -> str:
        try:
            if isinstance(data, (list, tuple)):
                numbers = [
                    float(x) for x in data if isinstance(x, (int, float))
                ]
                if numbers:
                    total = sum(numbers)
                    return f"sum={total}, avg={total / len(numbers)}"
                return "No numeric values found"
            return str(float(data))
        except ValueError as e:
            return f"Error processing data: {e}"
        except TypeError as e:
            return f"Error processing data: {e}"
        except OverflowError as e:
            return f"Error processing data: {e}"

    def validate(self, data: list | tuple | int | float) -> bool:
        if isinstance(data, (list, tuple)):
            for x in data:
                if not isinstance(x, (int, float)):
                    return False
        return isinstance(data, (int, float))


class TextProcessor(DataProcessor):
    pass


class LogProcessor(DataProcessor):
    pass


def main() -> None:
    pass


if __name__ == "__main__":
    main()
