class LogProcessor(DataProcessor):
    def format_output(self, result: str) -> str:
        return f"[RESULT] {result}"

    def process(self, data: Any) -> str:
        try:
            if isinstance(data, str):
                lines = data.strip().split("\n")
                if not lines or lines == [""]:
                    return self.format_output("Empty log data")
                
                log_levels = {"ERROR": 0, "WARN": 0, "INFO": 0, "DEBUG": 0}
                for line in lines:
                    line_upper = line.upper()
                    for level in log_levels:
                        if level in line_upper:
                            log_levels[level] += 1
                            break
                
                return self.format_output(
                    f"lines={len(lines)}, errors={log_levels['ERROR']}, "
                    f"warnings={log_levels['WARN']}, info={log_levels['INFO']}, "
                    f"debug={log_levels['DEBUG']}"
                )
            elif hasattr(data, "read"):
                content = data.read()
                return self.process(content)
            return self.format_output(f"Unsupported log format: {type(data).__name__}")
        except Exception as e:
            return self.format_output(f"Error processing log: {e}")

    def validate(self, data: Any) -> bool:
        if isinstance(data, str):
            return len(data.strip()) > 0
        if hasattr(data, "read"):
            return True
        return False